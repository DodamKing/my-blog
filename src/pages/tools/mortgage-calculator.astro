  otherTools={[
    { url: '/tools/loan-calculator', title: '일반 대출 계산기', desc: '상환방식별 비교' },
    { url: '/tools/jeonse-loan-calculator', title: '전세대출 계산기', desc: '월 이자·총 비용 계산' },
