<footer>
	<div class="container">
		<div class="footer-content">
			<p class="copyright">© {new Date().getFullYear()} <span class="gradient-text">Laon</span>. All rights reserved.</p>
			<ul class="footer-links">
				<li><a href="/about/">About</a></li>
				<li><a href="/blog/">전체 글</a></li>
				<li><a href="/rss.xml">RSS</a></li>
			</ul>
			<p class="contact">Contact: <a href="mailto:dimad.contact@gmail.com">dimad.contact@gmail.com</a></p>
		</div>
	</div>
</footer>

<style>
	footer {
		width: 100%;
		background: linear-gradient(to bottom, #fafafa 0%, #f3f4f6 100%);
		border-top: 1px solid #e5e7eb;
		margin-top: 4rem;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 2rem;
	}

	.footer-content {
		text-align: center;
	}

	.copyright {
		font-size: 0.9375rem;
		color: #6b7280;
		margin: 0 0 0.5rem 0;
		font-weight: 500;
	}

	.gradient-text {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-weight: 700;
	}

	.subtitle {
		font-size: 0.875rem;
		color: #9ca3af;
		margin: 0;
	}

	.heart {
		color: #ef4444;
		animation: heartbeat 1.5s ease-in-out infinite;
		display: inline-block;
	}

	.footer-links {
		list-style: none;
		display: flex;
		justify-content: center;
		gap: 1.25rem;
		margin: 0.75rem 0 0;
		padding: 0;
	}

	.footer-links li {
		margin: 0;
	}

	.footer-links a {
		font-size: 0.875rem;
		color: #6b7280;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.footer-links a:hover {
		color: #667eea;
	}

	.contact {
		font-size: 0.875rem;
		color: #9ca3af;
		margin: 0.75rem 0 0 0;
	}

	.contact a {
		color: #6b7280;
		text-decoration: none;
		transition: color 0.2s;
	}

	.contact a:hover {
		color: #667eea;
	}

	@keyframes heartbeat {
		0%, 100% {
			transform: scale(1);
		}
		25% {
			transform: scale(1.2);
		}
	}

	@media (max-width: 768px) {
		.container {
			padding: 2.5rem 1.5rem;
		}
	}
</style>